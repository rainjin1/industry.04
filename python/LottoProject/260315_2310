import random

# 자동 번호 생성기.
def auto_number_maker(number_of_bought_lotto: int): # 구매한 자동로또의 숫자를 매개변수로 받음.
    auto_ball_pool = [i for i in range(1, 46, 1)] # 먼저 볼풀을 45개의 숫자로 채움
    auto_picked_numbers = {} # 뽑힌 번호를 저장할 딕셔너리
    for i in range(number_of_bought_lotto): #딕셔너리에 구매한 수량만큼의 키값을 미리 넣어둠
        auto_picked_numbers[i] = []
    for auto_lottos in range(number_of_bought_lotto): # 구매한 숫자만큼 돌릴 자동뽑기를 돌릴예정
        for num in range(1, 7): #보너스번호까지 총 6개의 숫자 뽑기.
            random.shuffle(auto_ball_pool) # 공을 뽑기전에 랜덤으로 돌림 (하나가 제거된 경우에도 바로 뽑지 않고 랜덤으로 또 돌림)
            auto_picked_numbers[auto_lottos].append(auto_ball_pool[0]) # 랜덤으로 돌린 풀에서 첫번째 공을 가져와서 번호저장 딕셔너리에 추가
            del auto_ball_pool[0] # 뽑은 첫 공을 제거
        auto_ball_pool = [i for i in range(1, 46, 1)] #한싸이클 돌아서 공이 6개 빠졌으니, 다음 의 로또를 뽑기 전에 리스트를 다시 선언
    return auto_picked_numbers # 자동으로 추출된 번호를 담은 딕셔너리를 반환

# 고객이 직접 번호 선정
def pick_number(user_choice_quantity_of_buy: int): #구매수량을 매개변수로 받음.
    user_picked_numbers = {} #유저가 고른 번호들을 저장할 딕셔너리
    for i in range(user_choice_quantity_of_buy): #딕셔너리에 구매한 수량만큼의 키값을 미리 넣어둠.
        user_picked_numbers[i] = []
    for number in range(user_choice_quantity_of_buy): #구매수량만큼 반복
        char_bought_lotto = input("1~45까지의 숫자 6개를 ,로 구분해서 공백없이 넣어주세요 : ") # 숫자입력받아서
        char_bought_lotto_list = char_bought_lotto.replace(" ","").split(",") # 띄어쓰기와 콤마 제거해서 순수 숫자만 문자열로 필터링
        int_bought_lotto = list(map(int, char_bought_lotto_list)) # 문자열을 숫자로 변환해서 리스트에 넣음
        user_picked_numbers[number] = int_bought_lotto #유저가 고른 번호들을 딕셔너리에 저장
    return user_picked_numbers #유저가 고른 번호들이 들어있는 딕셔너리를 반환
    # 내가 산 번호를 확인하고싶다면
    # print(int_bought_lotto)


# 자동확인시스템
def checking_numbers(picked_numbers: list[int], winning_numbers: list[int], bonus_number: int): # 직접 찍은 번호 리스트, 당첨번호 리스트, 보너스번호를 매개변수로받음
    won_numbers = 0 # 일치번호 숫자 카운팅
    bonus_number_corrected: bool = False #보너스번호 일치유무
    for number in picked_numbers: # 내가 고른 번호를 하나씩 가져와서
        if number in winning_numbers: # 당첨번호와 하나씩 대조
            won_numbers += 1 # 당첨할 시, 당첨번호 카운트 + 1
        if number == bonus_number:
            bonus_number_corrected = True
    if won_numbers == 6:
        print("Congratulations! You won the lotto!")
    if won_numbers == 5 and bonus_number_corrected:
        print("Congratulations! You won 2nd place!")
    if won_numbers == 5 and bonus_number_corrected==False:
        print("Congratulations! You won 3rd place!")
    if won_numbers == 4:
        print("Congratulations! You won 4th place!")
    if won_numbers == 3:
        print("Congratulations! You won 5th place!")
    if won_numbers < 3:
        print("I'm sorry you lost.....")

