from pop import Sound, delay, Leds

sound = Sound()
led = Leds()
count = 0
led.allOff()
# threshold (임계값)를 변수로 빼두면 수정하기 편합니다.
threshold = 2100 

print("소리 감지 시작! (박수를 쳐보세요)")

while True:
    detected = False #감지했는지 안했는지 True, Flase변수. 와일문 돌릴때마다 False로 다시 바꿔줌.
    # 100번 정도 빠르게 샘플링해서 소리가 있는지 확인 / 이걸 안하면, 엄청 빠르게 계속 감지해서, 소리의 잔상이 남아서 그걸 여러번 카운트할 수 있음.
    for _ in range(100):
        value = sound.read()
        if value > threshold:
            detected = True
            # print(f"감지된 소리 크기: {value}") # 필요할 때만 주석 해제
            break # 소리가 감지되면 for 루프를 즉시 나감
            
    if detected: #for 루프 나갔음. 그런데, 아까 for루프에서 디텍티드 변수를 트루로 해둠. 그러니까 이 if문 실행
        count += 1
        print(f'현재 카운트: {count}')
        
        # 홀수면 켜고, 짝수면 끄기
        if count % 2 == 1:
            led[0].on()
        else:
            led[0].off()
        
        # 소리가 감지된 후 '박수 소리 하나'가 끝날 때까지 잠시 기다려줘야 중복 카운트를 방지
        delay(300) 
    
    # 루프를 적절히 느리게
    delay(100)
