from pop import Psd, delay, Leds
psd = Psd()
led_controller = [num for num in range(8)]
led = Leds()
while True:
    value = psd.readAverage() #이동평균필터
    distance = psd.calcDist(value)
    print(f'distance : {distance}cm')
    led_num = int(distance//10) # 새로운 변수 하나 생성. led 몇번까지 킬 지 정하기 위함. // 는 나누기 한 다음 몫만 가져오는 것을 의미. ex 3 // 5면 1.66666~ 나오는데, 1만 결과로 가져옴
    if led_num > 8: #led는 7번까지밖에 없어서, 최대 8로 제한 8인 이유는 아래에 포문을 돌릴때 범위를 8로 해야 0~7 8개의 led제어 가능.
        led_num = 8
    for i in range(8-led_num): # 포문 돌려서 0~7까지 중 불을 켤 것 정하기. 가까우면 다 켜짐.
        led[i].on()
    delay(500)
    led.allOff()
